<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- External storage files -->
    <external-files-path
        name="external_files"
        path="." />

    <!-- Cache directory (for CSV reports) -->
    <cache-path
        name="cache"
        path="." />

    <!-- Reports subdirectory in cache (specifically for CSV sharing) -->
    <cache-path
        name="reports"
        path="reports/" />

    <!-- Files directory -->
    <files-path
        name="files"
        path="." />

    <!-- External cache directory -->
    <external-cache-path
        name="external_cache"
        path="." />
</paths>
